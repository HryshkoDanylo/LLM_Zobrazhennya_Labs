import os
os.environ['TF_ENABLE_ONEDNN_OPTS'] = '0'

import cv2
import tensorflow as tf
from tensorflow.keras import layers, models
import matplotlib.pyplot as plt
import numpy as np
from skimage.restoration import denoise_tv_chambolle
from scipy.ndimage import rotate

MODEL_FILE = 'mnist_model.keras'
IMAGE_FOLDER = r"C:\Users\User\IdeaProjects\Lab 1 Lyngvistyka\imgs"

# Завантаження моделі
def get_model():
    if os.path.exists(MODEL_FILE):
        print(f"Знайдено збережену модель '{MODEL_FILE}'. Завантаження...")
        return tf.keras.models.load_model(MODEL_FILE)
    else:
        print("Модель не знайдено. Ініціалізація процесу навчання...")
        (x_train, y_train), (x_test, y_test) = tf.keras.datasets.mnist.load_data()
        x_train, x_test = x_train / 255.0, x_test / 255.0

        model = models.Sequential([
            layers.Flatten(input_shape=(28, 28)),
            layers.Dense(128, activation='relu'),
            layers.Dropout(0.2),
            layers.Dense(10, activation='softmax')
        ])

        model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
        model.fit(x_train, y_train, epochs=3, validation_split=0.18)

        model.save(MODEL_FILE)
        print(f"\nМодель успішно збережено: {MODEL_FILE}")
        return model

#Попередня обробка зображення
def prepare_image(file_path):
    img_array_from_file = np.fromfile(file_path, dtype=np.uint8)
    img = cv2.imdecode(img_array_from_file, cv2.IMREAD_GRAYSCALE)

    if img is None:
        raise ValueError(f"Помилка зчитування файлу: {file_path}")

    # Масштабування зображення для коректної роботи фільтрів
    height, width = img.shape
    if max(height, width) > 800:
        scale = 800 / max(height, width)
        img = cv2.resize(img, (int(width * scale), int(height * scale)))

    # Усунення шумів та фонових ліній
    blurred = cv2.GaussianBlur(img, (11, 11), 0)

    # Адаптив зображення
    thresh = cv2.adaptiveThreshold(
        blurred, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, cv2.THRESH_BINARY_INV, 51, 15
    )

    # Пошук контурів об'єкта
    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    if not contours:
        return np.zeros((28, 28), dtype=np.float32)

    # Фільтрація шумів та виділення основного контуру
    valid_contours = [c for c in contours if cv2.contourArea(c) > 50]
    best_contour = max(valid_contours, key=cv2.contourArea) if valid_contours else max(contours, key=cv2.contourArea)

    x, y, w, h = cv2.boundingRect(best_contour)
    digit_cropped = thresh[y:y+h, x:x+w]

    # Формування квадратного контейнера для збереження пропорцій
    max_dim = max(w, h)
    square_img = np.zeros((max_dim, max_dim), dtype=np.uint8)

    off_x = (max_dim - w) // 2
    off_y = (max_dim - h) // 2
    square_img[off_y:off_y+h, off_x:off_x+w] = digit_cropped

    # Збільшення товщини ліній (імітація маркерного стилю MNIST)
    kernel = np.ones((3, 3), np.uint8)
    square_img = cv2.dilate(square_img, kernel, iterations=3)

    # Масштабування до базового розміру 20x20
    resized_20x20 = cv2.resize(square_img, (20, 20), interpolation=cv2.INTER_AREA)

    # Центрування на полотні 28x28 (стандарт MNIST)
    final_28x28 = np.zeros((28, 28), dtype=np.uint8)
    final_28x28[4:24, 4:24] = resized_20x20

    # Нормалізація значень та застосування фільтра ROF
    img_float = final_28x28.astype(np.float32) / 255.0
    img_denoised = denoise_tv_chambolle(img_float, weight=0.1)

    return img_denoised

# Класифікація
def process_custom_image(model):
    print(f"\nРобоча директорія: {IMAGE_FOLDER}")
    filename = input("Назва файлу ").strip()

    if filename.lower() == 'q':
        return False

    file_path = os.path.join(IMAGE_FOLDER, filename)

    if not os.path.exists(file_path):
        print(f"Помилка: Файл '{filename}' не знайдено.")
        return True

    try:
        base_img = prepare_image(file_path)

        angles = [-45, -30, -15, 0, 15, 30, 45]

        results = []
        best_confidence = -1
        best_angle = 0

        # Ітерація за  кутами
        for angle in angles:
            rotated_img = rotate(base_img, angle, reshape=False, mode='constant', cval=0.0)
            img_batch = np.expand_dims(rotated_img, axis=0)

            prediction = model.predict(img_batch, verbose=0)[0]
            current_confidence = np.max(prediction)

            results.append({
                'angle': angle,
                'img': rotated_img,
                'probs': prediction
            })

            if current_confidence > best_confidence:
                best_confidence = current_confidence
                best_angle = angle

        # Візуалізація
        plt.figure(figsize=(18, 6))
        plt.suptitle(f"Аналіз зображення: {filename}", fontsize=16)

        for i, res in enumerate(results):
            plt.subplot(1, len(angles), i + 1)

            plt.imshow(res['img'], cmap='binary')

            img_probs = res['probs']
            top_10_indices = np.argsort(img_probs)[::-1]
            top_10_probs = img_probs[top_10_indices] * 100

            is_best = (res['angle'] == best_angle)
            title_color = 'green' if is_best else 'black'

            title_text = f"Кут: {res['angle']}°\n" + "-"*15 + "\n"
            for j in range(10):
                title_text += f"{j+1}. Цифра {top_10_indices[j]} ({top_10_probs[j]:.5f}%)\n"

            plt.title(title_text, color=title_color, fontsize=9, loc='left')
            plt.axis('off')

        plt.tight_layout()
        plt.show()

        return True

    except Exception as e:
        print(f"Помилка під час обробки: {e}")
        return True

if __name__ == "__main__":
    model = get_model()

    while True:
        user_continued = process_custom_image(model)

        if not user_continued:
            print("Thats it folks!")
            break
